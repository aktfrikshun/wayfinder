<div class="page-head">
  <div>
    <h1>Users</h1>
    <p>Manage authentication accounts and role assignments.</p>
  </div>
  <%= link_to "New User", new_user_path, class: "btn btn-primary" %>
</div>

<%= form_with url: users_path, method: :get, local: true, class: "toolbar" do %>
  <div style="flex: 1 1 320px;">
    <label for="q">Search</label>
    <%= text_field_tag :q, @query, placeholder: "Email or role" %>
  </div>
  <div style="display: flex; gap: 0.5rem; align-self: end;">
    <%= submit_tag "Filter", class: "btn" %>
    <%= link_to "Clear", users_path, class: "btn" %>
  </div>
<% end %>

<div class="table-wrap">
  <table class="table">
    <thead>
      <tr>
        <th>Email</th>
        <th>Role</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= link_to user.email, user_path(user) %></td>
          <td><%= user.role_label %></td>
          <td><%= user.created_at.strftime("%Y-%m-%d") %></td>
          <td>
            <div class="inline-actions">
              <%= link_to "Edit", edit_user_path(user), class: "btn" %>
              <% if user == current_user %>
                <span class="btn" style="opacity: 0.6;">Current User</span>
              <% else %>
                <%= button_to "Impersonate", impersonate_user_path(user), method: :post, class: "btn", form: { data: { turbo_confirm: "Impersonate #{user.email}?" } } %>
                <%= button_to "Delete", user_path(user), method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: "Delete this user?" } } %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
