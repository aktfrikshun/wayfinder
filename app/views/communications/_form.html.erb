<%= form_with model: communication, local: true do |form| %>
  <% if communication.errors.any? %>
    <div class="error-box">
      <strong><%= pluralize(communication.errors.count, "error") %> prevented save:</strong>
      <ul>
        <% communication.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid">
    <div class="full">
      <%= form.label :child_id, "Child" %>
      <%= form.collection_select :child_id, Child.order(:name), :id, :name, { prompt: "Select child" }, required: true %>
    </div>

    <div class="full">
      <%= form.label :correspondent_ids, "Correspondents" %>
      <%= form.collection_select :correspondent_ids, Correspondent.order(:name, :email), :id, :display_name, {}, { multiple: true, size: 6, required: true } %>
      <p class="muted">Select at least one correspondent for this communication.</p>
    </div>

    <div>
      <%= form.label :source %>
      <%= form.text_field :source %>
    </div>

    <div>
      <%= form.label :ai_status %>
      <%= form.select :ai_status, Communication::AI_STATUSES %>
    </div>

    <div>
      <%= form.label :from_email %>
      <%= form.email_field :from_email %>
    </div>

    <div>
      <%= form.label :from_name %>
      <%= form.text_field :from_name %>
    </div>

    <div class="full">
      <%= form.label :subject %>
      <%= form.text_field :subject %>
    </div>

    <div class="full">
      <%= form.label :received_at %>
      <%= form.datetime_local_field :received_at, value: communication.received_at&.strftime("%Y-%m-%dT%H:%M") %>
    </div>

    <div class="full">
      <%= form.label :body_text %>
      <%= form.text_area :body_text %>
    </div>

    <div class="full">
      <%= form.label :body_html %>
      <%= form.text_area :body_html %>
    </div>

    <div class="full">
      <%= form.label :raw_payload, "Raw Payload (JSON)" %>
      <%= form.text_area :raw_payload, value: JSON.pretty_generate(communication.raw_payload || {}) %>
    </div>

    <div class="full">
      <%= form.label :ai_raw_response, "AI Raw Response (JSON)" %>
      <%= form.text_area :ai_raw_response, value: communication.ai_raw_response.present? ? JSON.pretty_generate(communication.ai_raw_response) : "" %>
    </div>

    <div class="full">
      <%= form.label :ai_extracted, "AI Extracted (JSON)" %>
      <%= form.text_area :ai_extracted, value: communication.ai_extracted.present? ? JSON.pretty_generate(communication.ai_extracted) : "" %>
    </div>

    <div class="full">
      <%= form.label :ai_error %>
      <%= form.text_area :ai_error %>
    </div>
  </div>

  <div class="toolbar" style="margin-top: 1rem;">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", communications_path, class: "btn" %>
  </div>
<% end %>
