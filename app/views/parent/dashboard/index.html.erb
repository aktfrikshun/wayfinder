<div class="page-head">
  <div>
    <h1>Parent Dashboard</h1>
    <p>Welcome <%= @parent.name.presence || @parent.email %>. Manage children and review school communications.</p>
  </div>
  <div class="inline-actions">
    <%= link_to "Add Child", new_parent_child_path, class: "btn btn-primary" %>
    <%= link_to "View Communications", parent_communications_path, class: "btn" %>
  </div>
</div>

<div class="grid grid-3">
  <section class="card">
    <h3>Children</h3>
    <div class="metric"><%= @children.count %></div>
  </section>
  <section class="card">
    <h3>Communications</h3>
    <div class="metric"><%= @artifacts_count %></div>
  </section>
  <section class="card">
    <h3>Latest Activity</h3>
    <p class="muted" style="margin-top: 0.5rem;"><%= @recent_artifacts.first&.occurred_at&.strftime("%Y-%m-%d %H:%M") || @recent_artifacts.first&.captured_at&.strftime("%Y-%m-%d %H:%M") || "No messages yet" %></p>
  </section>
</div>

<section class="card" style="margin-top: 1rem;">
  <div class="page-head" style="margin-bottom: 0.75rem;">
    <div>
      <h3>Your Children</h3>
    </div>
    <%= link_to "Manage Children", parent_children_path, class: "btn" %>
  </div>

  <% if @children.any? %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Grade</th>
            <th>School</th>
            <th>Alias</th>
          </tr>
        </thead>
        <tbody>
          <% @children.each do |child| %>
            <tr>
              <td><%= link_to child.name, parent_child_path(child) %></td>
              <td><%= child.grade.presence || "-" %></td>
              <td><%= child.school_name.presence || "-" %></td>
              <td><%= child.inbound_alias.presence || "-" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted">No children added yet.</p>
  <% end %>
</section>
