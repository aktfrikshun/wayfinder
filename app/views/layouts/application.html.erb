<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Wayfinder" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Wayfinder">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body>
    <header class="site-header">
      <div class="shell nav-wrap">
        <%= link_to "Wayfinder", root_path, class: "brand" %>
        <nav class="nav-links">
          <% if user_signed_in? %>
            <% if current_user.admin_role? %>
              <%= link_to "Dashboard", root_path, class: "nav-link" %>
              <%= link_to "Parents", parents_path, class: "nav-link" %>
              <%= link_to "Children", children_path, class: "nav-link" %>
              <%= link_to "Artifacts", artifacts_path, class: "nav-link" %>
              <%= link_to "Communications", communications_path, class: "nav-link" %>
              <%= link_to "Users", users_path, class: "nav-link" %>
            <% elsif current_user.parent_role? %>
              <%= link_to "Dashboard", parent_root_path, class: "nav-link" %>
              <%= link_to "My Children", parent_children_path, class: "nav-link" %>
              <%= link_to "Communications", parent_communications_path, class: "nav-link" %>
              <%= link_to "Family Invitations", parent_invitations_path, class: "nav-link" %>
            <% else %>
              <%= link_to "Portal", portal_path, class: "nav-link" %>
            <% end %>

            <% if impersonating? %>
              <span class="nav-pill">Impersonating · <%= current_user.email %></span>
              <%= button_to "Stop Impersonating", stop_impersonating_path, method: :delete, class: "nav-link nav-button" %>
            <% end %>

            <span class="nav-pill"><%= current_user.email %> · <%= current_user.role_label %></span>
            <%= link_to "Profile", edit_profile_correspondent_path, class: "nav-link" %>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "nav-link nav-button" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "nav-link" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="shell">
      <% flash.each do |kind, message| %>
        <div class="flash flash-<%= kind %>"><%= message %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
