<%= form_with model: child, local: true do |form| %>
  <% if child.errors.any? %>
    <div class="error-box">
      <strong><%= pluralize(child.errors.count, "error") %> prevented save:</strong>
      <ul>
        <% child.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid">
    <div class="full">
      <%= form.label :parent_id, "Parent" %>
      <%= form.collection_select :parent_id, Parent.order(:email), :id, :email, { prompt: "Select parent" }, required: true %>
    </div>

    <div>
      <%= form.label :name %>
      <%= form.text_field :name, required: true %>
    </div>

    <div>
      <%= form.label :grade %>
      <%= form.text_field :grade %>
    </div>

    <div>
      <%= form.label :school_name %>
      <%= form.text_field :school_name %>
    </div>

    <div>
      <%= form.label :inbound_alias %>
      <%= form.text_field :inbound_alias %>
    </div>
  </div>

  <div class="toolbar" style="margin-top: 1rem;">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", children_path, class: "btn" %>
  </div>
<% end %>
