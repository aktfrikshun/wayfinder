<div class="page-head">
  <div>
    <h1><%= @artifact.display_title %></h1>
    <p><%= @artifact.child.name %> · <%= @artifact.occurred_at&.strftime("%Y-%m-%d %H:%M") || @artifact.captured_at&.strftime("%Y-%m-%d %H:%M") || "No timestamp" %></p>
  </div>
  <div class="inline-actions">
    <%= link_to "Back", parent_communications_path, class: "btn" %>
  </div>
</div>

<div class="grid grid-2">
  <section class="card">
    <h3>Message Details</h3>
    <p><strong>From:</strong> <%= @artifact.from_name.presence || "-" %> &lt;<%= @artifact.from_email.presence || "-" %>&gt;</p>
    <p><strong>Status:</strong> <span class="badge badge-<%= @artifact.ai_status %>"><%= @artifact.ai_status %></span></p>
    <p><strong>Source:</strong> <%= @artifact.source.presence || "-" %></p>
    <p><strong>Category:</strong> <%= @artifact.effective_category.presence || "-" %></p>
  </section>

  <section class="card">
    <h3>AI Summary</h3>
    <% if @artifact.extracted_payload.present? %>
      <pre style="white-space: pre-wrap;"><%= JSON.pretty_generate(@artifact.extracted_payload) %></pre>
    <% else %>
      <p class="muted">No AI extraction available yet.</p>
    <% end %>
  </section>
</div>

<section class="card" style="margin-top: 1rem;">
  <h3>Body</h3>
  <p style="white-space: pre-wrap;"><%= @artifact.normalized_text.presence || @artifact.body_text.presence || "No text body" %></p>
</section>
