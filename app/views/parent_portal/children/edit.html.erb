<div class="page-head">
  <div>
    <h1>Edit Child</h1>
    <p>Update child information and alias details.</p>
  </div>
</div>

<section class="card">
  <%= render "form", child: @child %>
</section>

<section class="card" style="margin-top: 1rem;">
  <div class="page-head" style="margin-bottom: 0.5rem;">
    <div>
      <h3>Child Email Code</h3>
      <p class="muted">Copy this address on school emails to attach them to <%= @child.name %>'s history.</p>
    </div>
    <%= button_to "Regenerate Code", regenerate_alias_parent_child_path(@child), method: :post, class: "btn" %>
  </div>

  <% if @child.inbound_alias.present? %>
    <p><strong>Code:</strong> <code><%= @child.inbound_alias %></code></p>
    <p style="display: flex; align-items: center; gap: 0.5rem;">
      <span><strong>Forward-to email:</strong> <code id="child-forward-email"><%= "#{@child.inbound_alias}-#{@child.id}@wf.frikshun.com" %></code></span>
      <button type="button" class="btn" data-copy-target="#child-forward-email">Copy</button>
    </p>
  <% else %>
    <p class="muted">No code yet. Regenerate to create one.</p>
  <% end %>

  <p style="margin-top: 0.5rem;" class="muted">
    Any email where this address is on To/CC will be ingested and added to your child's development history. The child ID suffix ensures the message is routed correctly.
  </p>

  <script>
    document.addEventListener("turbo:load", () => {
      document.querySelectorAll('[data-copy-target]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = document.querySelector(btn.dataset.copyTarget);
          if (!target) return;
          const text = target.textContent.trim();
          navigator.clipboard?.writeText(text);
          btn.textContent = "Copied";
          setTimeout(() => (btn.textContent = "Copy"), 1200);
        });
      });
    });
  </script>
</section>

<section class="card" style="margin-top: 1rem;">
  <div class="page-head" style="margin-bottom: 0.75rem;">
    <div>
      <h3>Your Communications For <%= @child.name %></h3>
      <p class="muted">You can edit communications you are involved in and manage their artifacts.</p>
    </div>
    <%= link_to "Add Communication", new_parent_child_communication_path(@child), class: "btn btn-primary" %>
  </div>

  <% if @involved_communications.any? %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Subject</th>
            <th>Correspondents</th>
            <th>Received</th>
            <th>Artifacts</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @involved_communications.each do |communication| %>
            <tr>
              <td><%= communication.subject.presence || "(No Subject)" %></td>
              <td><%= communication.correspondents.map(&:display_name).join(", ") %></td>
              <td><%= communication.received_at&.strftime("%Y-%m-%d %H:%M") || "-" %></td>
              <td><%= communication.artifacts.count %></td>
              <td>
                <div class="inline-actions">
                  <%= link_to "Edit", edit_parent_child_communication_path(@child, communication), class: "btn" %>
                  <%= button_to "Delete", parent_child_communication_path(@child, communication), method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: "Delete this communication and its artifacts?" } } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted">No communications yet where you are a correspondent.</p>
  <% end %>
</section>
